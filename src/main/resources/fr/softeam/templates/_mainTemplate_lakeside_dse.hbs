tosca_definitions_version: tosca_simple_yaml_1_3

metadata:
{{#ownedAttribute as |metadata|}}
{{#metadata.extension as |extension|}}
{{#eq extension.name "Metadata"}}
  {{metadata.name}}: {{{formatYamlValue metadata.value}}}
{{/eq}}
{{/metadata.extension}}
{{/ownedAttribute}}
topology_template:
{{{lakesideSystemParams this "  "}}}
{{{lakesideArchitecture this "  "}}}
  node_templates:
{{#lakesideNodeTemplates this}}
{{> LakesideNodeTemplate this}}
{{/lakesideNodeTemplates}}

